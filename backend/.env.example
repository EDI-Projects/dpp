# Backend runtime configuration
# Copy to backend/.env for local development.

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:3000

# Optional CSV overrides (defaults are used when unset)
CSV_PATH=../data/factory_data.csv
MATERIALS_PATH=../data/MOCK_DATA (3).csv
PRODUCTION_PATH=../data/y1AQEIpMTR2j7xgr9MH0_Manufacturing Dataset.csv

# Secret for key-protection features (future persistence work)
DPP_KEY_SECRET=change-me-in-production

# PostgreSQL database connection (REQUIRED — no in-memory fallback)
DATABASE_URL=postgresql://dpp_user:change-me-in-production@localhost:5432/dpp_db

# ── IPFS via Pinata ──────────────────────────────────────────────────────────
# Get a free JWT at https://pinata.cloud
# If not set, IPFS pinning is skipped (credentials stored locally only)
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Polygon On-Chain Anchoring ───────────────────────────────────────────────
# Amoy testnet RPC (free from Alchemy/Infura/public endpoints)
# If not set, on-chain anchoring is skipped
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_PRIVATE_KEY=
POLYGON_CONTRACT_ADDRESS=
